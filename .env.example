# Hostinger SSH Configuration
# Copy this file to .env and fill in your actual credentials

HOSTINGER_SSH_ALIAS=your-ssh-alias
HOSTINGER_SSH_USER=your-username
HOSTINGER_SSH_HOST=your-server-ip
HOSTINGER_SSH_PORT=22
HOSTINGER_PATH=domains/yourdomain.com/public_html/

# Site Configuration
SITE_URL=https://yourdomain.com

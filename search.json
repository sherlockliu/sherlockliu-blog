---
layout: none
permalink: /search.json
---
{% assign published_posts = site.posts | where_exp: "post", "post.published != false" %}
[{% for post in published_posts %}{"title":{{ post.title | jsonify }},"url":{{ post.url | relative_url | jsonify }},"description":{{ post.description | default: "" | jsonify }},"date":{{ post.date | date: "%b %d, %Y" | jsonify }},"read_time":{{ post.read_time | default: "" | jsonify }},"categories":{{ post.categories | join: ", " | jsonify }},"series_name":{{ post.series.name | default: "" | jsonify }},"series_part":{{ post.series.part | default: 0 | jsonify }},"series_total":{{ post.series.total | default: 0 | jsonify }},"content":{{ post.content | strip_html | normalize_whitespace | truncatewords: 800 | jsonify }}}{% unless forloop.last %},{% endunless %}{% endfor %}]
